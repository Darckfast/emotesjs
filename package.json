{
    "name": "emotesjs",
    "description": "Fast, dependency free, and responsive 7TV inline emotes parse",
    "version": "1.0.0",
    "license": "MIT",
    "author": {
        "name": "darckfast"
    },
    "engines": {
        "node": ">=22"
    },
    "files": [
        "dist"
    ],
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/darckfast/emotesjs.git"
    },
    "keywords": [
        "twitch",
        "7tv",
        "emotes",
        "responsive"
    ],
    "scripts": {
        "test": "vitest run",
        "prepublishOnly": "pnpx tsup && pnpx terser ./dist/index.js -o ./dist/index.js"
    },
    "devDependencies": {
        "tsup": "^8.5.1",
        "typescript": "^6.0.3",
        "vitest": "^3.2.4"
    }
}
